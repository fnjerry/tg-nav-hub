# https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 直连若超时（TimeoutError），填本地代理；端口以 Clash / v2rayN 为准（常见 7890、10808）
# TELEGRAM_PROXY=socks5://127.0.0.1:7890
# TELEGRAM_PROXY=socks5h://127.0.0.1:7890
# TELEGRAM_PROXY=http://127.0.0.1:7890

# --- 采集「他人公开频道」推荐配置（你自己的账号登录，无需 Bot 当管理员）---
# 任选其一：
# 1) 登录脚本输出的整串（见 scripts/login_telegram.py）
TELEGRAM_SESSION_STRING=

# 2) 不配字符串则用本地会话文件（默认 data/user_session → data/user_session.session）
# TELEGRAM_SESSION_FILE=data/user_session

# （可选）若你能把 Bot 加成频道管理员，可填 Bot Token；与上面用户会话二选一优先 Bot
# TELEGRAM_BOT_TOKEN=

# 多个公开频道用户名，英文逗号分隔，不要 @
TELEGRAM_CHANNELS=awesome_channels,daily_tools,qumao

# POST /api/sync：Authorization: Bearer <token>
ADMIN_SYNC_TOKEN=please-change-this-secret

HOST=127.0.0.1
# 固定 8765，勿改（占用时运行 scripts/free_port.ps1）
PORT=8765

# 每天本机 9:00 自动采集（需 uvicorn 常驻；也可用 scripts/daily_sync.ps1 + 任务计划程序）
ENABLE_DAILY_SYNC=true
DAILY_SYNC_TIME=09:00

# --- 云端部署（Render / Railway 等）在控制台配置，不要写进 Git ---
# DATABASE_PATH=/data/nav.db
# 云端由平台注入 PORT，无需设置；本地固定 PORT=8765
